<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ios_dialog_bg_top"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="Focus Duration"
            android:textColor="@color/ios_text_secondary"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ios_separator" />

        <TextView
            android:id="@+id/btn30Min"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="30 Minutes"
            android:textColor="@color/ios_blue"
            android:textSize="20sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ios_separator" />

        <TextView
            android:id="@+id/btn1Hour"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="1 Hour"
            android:textColor="@color/ios_blue"
            android:textSize="20sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ios_separator" />

        <TextView
            android:id="@+id/btn2Hours"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="2 Hours"
            android:textColor="@color/ios_blue"
            android:textSize="20sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ios_separator" />

        <TextView
            android:id="@+id/btn3Hours"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="3 Hours"
            android:textColor="@color/ios_blue"
            android:textSize="20sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/ios_dialog_bg_single"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Cancel"
        android:textColor="@color/ios_blue"
        android:textSize="20sp" />

</LinearLayout>